---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allLinks = (await getCollection('links')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function relativeTime(date: Date): string {
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const mins = Math.floor(diff / 60000);
  const hours = Math.floor(diff / 3600000);
  const days = Math.floor(diff / 86400000);
  if (mins < 60) return `${mins} 分钟前`;
  if (hours < 24) return `${hours} 小时前`;
  if (days < 30) return `${days} 天前`;
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

function getDomain(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
}

async function fetchOgImage(url: string): Promise<string | null> {
  try {
    const res = await fetch(url, {
      signal: AbortSignal.timeout(4000),
      headers: { 'User-Agent': 'Mozilla/5.0 (compatible; feilong-bot/1.0)' },
    });
    const html = await res.text();
    const m =
      html.match(/<meta[^>]+property=["']og:image["'][^>]+content=["']([^"']+)["']/i) ||
      html.match(/<meta[^>]+content=["']([^"']+)["'][^>]+property=["']og:image["']/i);
    const src = m ? m[1] : null;
    if (!src) return null;
    return src.startsWith('http') ? src : new URL(src, url).href;
  } catch {
    return null;
  }
}

const renderedLinks = await Promise.all(
  allLinks.map(async (link) => {
    const { Content } = await link.render();
    const image = link.data.image ?? (await fetchOgImage(link.data.url));
    return { ...link, Content, image };
  })
);
---

<Layout title="链接 · 飞龙" description="收藏的文章与链接">
  <div class="links-page">
    <h1 class="page-title">链接</h1>
    <p class="page-desc">值得一读的文章和链接。</p>

    <div class="link-list">
      {renderedLinks.map((link, i) => {
        const LinkContent = link.Content;
        return (
        <article class="link-item">
          <!-- 卡片头部：标题 + 缩略图 -->
          <div class="link-card-header">
            <div class="link-card-left">
              <h2 class="link-title">
                <a href={link.data.url} target="_blank" rel="noopener noreferrer">
                  {link.data.title}
                </a>
              </h2>
              <span class="domain-text">{getDomain(link.data.url)}</span>
            </div>
            {link.image && (
              <a href={link.data.url} target="_blank" rel="noopener noreferrer" class="link-thumb">
                <img src={link.image} alt="" loading="lazy" />
              </a>
            )}
          </div>

          <!-- 摘要正文 -->
          <div class="link-body">
            <div class="link-content collapsed" data-id={i}>
              <LinkContent />
            </div>
            <button class="expand-btn" data-id={i}>查看更多</button>
          </div>

          <!-- 底部：标签 + 时间 -->
          <div class="link-footer">
            <span class={`tag tag-${link.data.type}`}>
              #{link.data.type === 'article' ? 'Article' : 'Link'}
            </span>
            <span class="link-time">{relativeTime(link.data.date)}</span>
          </div>
        </article>
        );
      })}
    </div>
  </div>
</Layout>

<style>
  .links-page {
    max-width: 100%;
  }

  .page-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .page-desc {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* 卡片 */
  .link-item {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.1rem 1.2rem 0.9rem;
    background: var(--color-bg);
    transition: box-shadow 0.15s;
  }

  .link-item:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  }

  @media (prefers-color-scheme: dark) {
    .link-item:hover {
      box-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }
  }

  /* 头部：标题区 + 缩略图 */
  .link-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .link-card-left {
    flex: 1;
    min-width: 0;
  }

  .link-title {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.2rem;
  }

  .link-title a {
    text-decoration: none;
    color: var(--color-text);
  }

  .link-title a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.75;
  }

  .domain-text {
    font-size: 0.78rem;
    color: var(--color-muted);
  }

  /* 缩略图 */
  .link-thumb {
    flex-shrink: 0;
    width: 72px;
    height: 54px;
    border-radius: 6px;
    overflow: hidden;
    display: block;
  }

  .link-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 摘要正文 */
  .link-body {
    margin-bottom: 0.75rem;
  }

  .link-content {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text);
    overflow: hidden;
  }

  .link-content.collapsed {
    max-height: 4.9em;
    -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
  }

  .link-content.expanded {
    max-height: none;
    -webkit-mask-image: none;
    mask-image: none;
  }

  .link-content :global(p) {
    margin-bottom: 0.6rem;
  }

  .link-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .expand-btn {
    background: none;
    border: none;
    padding: 0.25rem 0;
    font-size: 0.8rem;
    color: var(--color-muted);
    cursor: pointer;
    display: block;
    margin-top: 0.3rem;
  }

  .expand-btn:hover {
    color: var(--color-text);
  }

  .expand-btn.hidden {
    display: none;
  }

  /* 底部 */
  .link-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    padding-top: 0.6rem;
    border-top: 1px solid var(--color-border);
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-muted);
    font-weight: 500;
  }

  .link-time {
    font-size: 0.75rem;
    color: var(--color-muted);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.expand-btn').forEach((btn) => {
    const id = btn.dataset.id;
    const content = document.querySelector<HTMLElement>(`.link-content[data-id="${id}"]`);
    if (!content) return;

    // 如果内容不超出，隐藏按钮
    if (content.scrollHeight <= content.clientHeight + 4) {
      btn.classList.add('hidden');
      content.classList.remove('collapsed');
      return;
    }

    btn.addEventListener('click', () => {
      const isCollapsed = content.classList.contains('collapsed');
      content.classList.toggle('collapsed', !isCollapsed);
      content.classList.toggle('expanded', isCollapsed);
      btn.textContent = isCollapsed ? '收起 ↑' : '查看更多 ↓';
    });
  });
</script>
